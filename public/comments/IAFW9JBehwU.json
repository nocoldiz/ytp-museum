[{"id":"Ugz2tnqRv_TqZQt4uqZ4AaABAg","parent":"root","text":"Quel disco solistico di Roger Waters mi piace davvero tanto e mi piace da matti il concept del disco. Fun Fact: In origine la maggior parte dell'album doveva essere The Wall, solo che venne accantonato dai Pink Floyd. Così Roger, lo riprese in mano e fece quel disco. Per fortuna non venne accantonato, perché ripeto, mi piace molto.","like_count":1,"author_id":"UC9qrnossa4h3eoolphn18qQ","author":"@thedevilgood78","author_thumbnail":"https://yt3.ggpht.com/0sQJ65UIye7Jh7RPgxWGWAQv51A7QlbguR3h2LjKfqV0-qdN9w79AqIlPePLgE5RpJqO0WdB=s88-c-k-c0x00ffffff-no-rj","author_is_uploader":false,"author_is_verified":false,"author_url":"https://www.youtube.com/@thedevilgood78","is_favorited":true,"_time_text":"1 year ago","timestamp":1745884800,"is_pinned":false},{"id":"UgyJoBfVEhTf2kD03o14AaABAg","parent":"root","text":"Ragione al 150%.","like_count":0,"author_id":"UCQJNasgzmHGhx0JRcSVpe9A","author":"@alessandromariani99","author_thumbnail":"https://yt3.ggpht.com/ytc/AIdro_kdcp_1CBaYZcJ3N8gvlE4zfF-Of9HKPPYNjnoqTfN6X0k=s88-c-k-c0x00ffffff-no-rj","author_is_uploader":false,"author_is_verified":false,"author_url":"https://www.youtube.com/@alessandromariani99","is_favorited":true,"_time_text":"1 year ago","timestamp":1745884800,"is_pinned":false}]