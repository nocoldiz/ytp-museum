[{"id":"Ugx8IiOEOAUMxbXw_Vd4AaABAg","parent":"root","text":"La dissacrazione dei Deep Purple","like_count":1,"author_id":"UC9qrnossa4h3eoolphn18qQ","author":"@thedevilgood78","author_thumbnail":"https://yt3.ggpht.com/0sQJ65UIye7Jh7RPgxWGWAQv51A7QlbguR3h2LjKfqV0-qdN9w79AqIlPePLgE5RpJqO0WdB=s88-c-k-c0x00ffffff-no-rj","author_is_uploader":false,"author_is_verified":false,"author_url":"https://www.youtube.com/@thedevilgood78","is_favorited":true,"_time_text":"1 year ago","timestamp":1745884800,"is_pinned":false},{"id":"UgydCtp_C4jVRTrWdRV4AaABAg","parent":"root","text":"Aveva pienamente ragione! Steve Morse non c'entra niente con i Deep Purple. Tanti gruppi hanno cambiato elementi cardine e hanno mantenuto la loro anima. Non loro. Grande Richard","like_count":1,"author_id":"UCpFuoc6LcoNrEnW3IQEWT0Q","author":"@riccgre6453","author_thumbnail":"https://yt3.ggpht.com/ytc/AIdro_mbSrquteJWjVwyKNaVO20dwGjuYwOZ6xqhT_cQsxrdQoLYtpU-2i-jxZiqoDp5N2pbQrw=s88-c-k-c0x00ffffff-no-rj","author_is_uploader":false,"author_is_verified":false,"author_url":"https://www.youtube.com/@riccgre6453","is_favorited":true,"_time_text":"1 year ago","timestamp":1745884800,"is_pinned":false},{"id":"UgxoMSSd_OjHswqiqdF4AaABAg","parent":"root","text":"A me Purpendicular non dispiace affatto, quindi non sono d'accordissimo con Benson, però sta insegnando a tutti come si fa una critica argomentata e come esprimere il proprio giudizio, anche negativo, senza offendere nessuno.","like_count":4,"author_id":"UC5vCOuimUOpLfT5HW3TQo5A","author":"@SimoneCalloni","author_thumbnail":"https://yt3.ggpht.com/ytc/AIdro_nBTKtvvlGLrg8pBPqxBevOL2fUGQZ52wX_nNXV-GTpQdY=s88-c-k-c0x00ffffff-no-rj","author_is_uploader":false,"author_is_verified":false,"author_url":"https://www.youtube.com/@SimoneCalloni","is_favorited":true,"_time_text":"1 year ago","timestamp":1745884800,"is_pinned":false},{"id":"UgxoMSSd_OjHswqiqdF4AaABAg.A5pqXDmxMBxA5pt_dtK065","parent":"UgxoMSSd_OjHswqiqdF4AaABAg","text":"Sono d'accordo, Purpendicular penso